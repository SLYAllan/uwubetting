# --- Discord (obligatoire) ---
DISCORD_TOKEN=ton_token_bot
GUILD_ID=id_de_ton_serveur

# --- Source des matchs ---
PROVIDER=sportsdb            # 'sportsdb' (foot/NBA) ou 'pandascore' (esport)

# Foot / NBA (PROVIDER=sportsdb)
SPORTSDB_API_KEY=3          # '3' = clé de test publique gratuite
LEAGUE_ID=4328              # 4328 Premier League · 4334 Ligue 1 · 4387 NBA
SEASON=2025-2026            # format saison TheSportsDB

# Esport (PROVIDER=pandascore) — SEASON est ignoré
PANDASCORE_TOKEN=ton_token_pandascore
# LEAGUE_ID pour PandaScore : 4197 LEC · 293 LCK · 4197... (voir README)
