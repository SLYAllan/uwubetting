# --- Discord (obligatoire) ---
DISCORD_TOKEN=ton_token_bot
GUILD_ID=id_de_ton_serveur

# --- Source des matchs ---
PROVIDER=espn                # 'espn' (foot/NBA, gratuit) · 'pandascore' (esport)

# Foot / NBA (PROVIDER=espn) — gratuit, sans clé, SEASON ignoré
LEAGUE_ID=soccer/eng.1       # soccer/fifa.world (CDM) · soccer/eng.1 · soccer/fra.1 · basketball/nba
SEASON=

# Esport (PROVIDER=pandascore) — SEASON est ignoré
PANDASCORE_TOKEN=ton_token_pandascore
# LEAGUE_ID pour PandaScore : 4197 LEC · 293 LCK · 4197... (voir README)
